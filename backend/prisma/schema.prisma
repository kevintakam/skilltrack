// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  password   String
  name       String
  avatar     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  objectives Objective[]
  habits     Habit[]
  sessions   Session[]
}

model Objective {
  id        String    @id @default(cuid())
  title     String
  emoji     String    @default("🎯")
  category  String    @default("learning")
  targetMin Int // minutes par jour cibles
  deadline  DateTime?
  progress  Float     @default(0) // 0.0 a 1.0
  status    String    @default("active") // active | paused | done
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  sessions  Session[]
  habits    Habit[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Habit {
  id          String            @id @default(cuid())
  title       String
  emoji       String            @default("✅")
  frequency   String            @default("daily") // daily | weekly
  targetDays  Int[] // ex: [1,2,3,4,5] pour lun-ven
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  objectiveId String?
  objective   Objective?        @relation(fields: [objectiveId], references: [id])
  completions HabitCompletion[]
  createdAt   DateTime          @default(now())
}

model HabitCompletion {
  id      String   @id @default(cuid())
  habitId String
  habit   Habit    @relation(fields: [habitId], references: [id])
  date    DateTime @default(now())

  @@unique([habitId, date]) // une seule completion par jour
}

model Session {
  id          String    @id @default(cuid())
  durationMin Int // duree en minutes
  note        String?
  startedAt   DateTime
  endedAt     DateTime
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id])
  createdAt   DateTime  @default(now())
}
